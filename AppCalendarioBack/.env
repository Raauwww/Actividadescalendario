# Base de datos
DB_HOST=localhost
DB_PORT=3306
DB_NAME=agendador_actividades
DB_USER=root
DB_PASSWORD=

# JWT
JWT_SECRET=tu_jwt_secret_super_seguro_aqui_cambiar_en_produccion
JWT_EXPIRE=7d

# Servidor
PORT=5000
NODE_ENV=development

# URLs del frontend
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Configuración de archivos
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Email (OPCIONAL - Deja vacío para deshabilitar notificaciones por email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# WhatsApp API (OPCIONAL - Deja vacío para deshabilitar notificaciones por WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Configuración de notificaciones (true/false)
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_WHATSAPP_NOTIFICATIONS=false
ENABLE_SYSTEM_NOTIFICATIONS=true